# ── Anthropic API Keys ────────────────────────────────────────────────
# You can use a single key for both agents, or separate keys for cost tracking.

# Discovery Agent (Data Understanding tab)
DISCOVERY_API_KEY=sk-ant-...

# Scenario Agent (Scenario tab)
SCENARIO_API_KEY=sk-ant-...

# ── Claude Models (optional overrides) ───────────────────────────────
# DISCOVERY_MODEL=claude-sonnet-4-6
# SCENARIO_MODEL=claude-sonnet-4-6

# ── Power BI MCP executable path ─────────────────────────────────────
# Required for PBI Desktop connections. Set to the full path of the
# powerbi-modeling-mcp.exe in your VS Code extensions folder.
# Example (Windows):
# POWERBI_MCP_EXE=C:\Users\YourName\.vscode\extensions\analysis-services.powerbi-modeling-mcp-0.1.9-win32-x64\server\powerbi-modeling-mcp.exe
POWERBI_MCP_EXE=
